# 东方财富妙想金融 API Key
# 申请地址：https://ai.eastmoney.com
# 设置方式：export EM_API_KEY="your_api_key_here"
EM_API_KEY=your_api_key_here

# 多 Token 配额轮换（可选，逗号分隔）
# 说明：原生脚本仅读取 EM_API_KEY，多 Token 轮换需由外层封装实现
# EM_API_KEY_POOL=em_xxx,em_yyy,em_zzz

# iwencai 语义检索 API Key（可选，仅 a_stock_research 的 NL 主题检索需要）
# 申请地址：https://www.iwencai.com/skillhub
# 其余 a-stock-data 端点全部免费免 key
# IWENCAI_API_KEY=
# IWENCAI_BASE_URL=https://openapi.iwencai.com
